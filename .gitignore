# Runtime data - not tracked in version control
memory/

# Logs (ignore content but keep directory placeholder)
logs/*
!logs/.gitkeep

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Notes (user-generated runtime content - not tracked)
notes/*
!notes/.gitkeep

# Environment
.env
.env.*
!.env.example

# Virtual environments
venv/
.venv/
env/

# OS artifacts
.DS_Store
Thumbs.db
