# LLM
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=lumina-model
OLLAMA_NUM_GPU=16
OLLAMA_NUM_THREAD=8
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# Voice
WHISPER_MODEL=base
WAKE_WORD=hey lumina
WAKE_WORD_THRESHOLD=0.85
SILENCE_TIMEOUT=1.5

# TTS
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# Memory
CHROMA_PATH=./memory
MEMORY_TOP_K=5

# Notes
NOTES_PATH=./notes

# UI
ALWAYS_ON_TOP=false
WINDOW_OPACITY=0.95

# Logging
LOG_LEVEL=INFO
LOG_PATH=./logs
